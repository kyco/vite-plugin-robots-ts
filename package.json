{
  "name": "vite-plugin-robots-ts",
  "version": "1.0.4",
  "description": "A Vite plugin to generate robots.txt. Allows AI blocking and also works in development mode.",
  "author": "Cornelius Weidmann <cornelius@kyco.io> (https://kyco.io)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "robots",
    "robots.txt",
    "typescript"
  ],
  "homepage": "https://kyco.github.io/vite-plugin-robots-ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyco/vite-plugin-robots-ts.git"
  },
  "bugs": {
    "url": "https://github.com/kyco/vite-plugin-robots-ts/issues"
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "echo \"This project does not have any tests which can be run yet...\"",
    "prepublishOnly": "tsup",
    "update-packages": "pnpm dlx npm-check-updates -u"
  },
  "packageManager": "pnpm@10.31.0",
  "peerDependencies": {
    "vite": ">=2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.5",
    "@semantic-release/npm": "^13.1.4",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}

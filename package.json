{
  "name": "vite-plugin-robots-ts",
  "version": "0.1.0",
  "description": "A Vite plugin to generate a robots.txt file. Allows AI blocking and also works in development mode.",
  "author": "Cornelius Weidmann <cornelius@kyco.io> (https://kyco.io)",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "provenance": true
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "robots",
    "robots.txt",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kyco/vite-plugin-robots-ts"
  },
  "scripts": {
    "build": "tsup",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "echo \"This project does not have any tests which can be run yet...\"",
    "prepublishOnly": "tsup",
    "update-packages": "pnpm dlx npm-check-updates -u"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
